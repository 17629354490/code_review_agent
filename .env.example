# Code Review Agent - 环境变量示例
# 复制为 .env 并填写

# ========== LLM ==========
# OpenAI
OPENAI_API_KEY=

# 或使用兼容端点（如 Ollama、国产大模型）
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_MODEL=llama3
# LLM_API_KEY=ollama

LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60

# ========== API 安全 ==========
# 多个 key 逗号分隔；留空则不做 API Key 校验（仅开发用）
API_KEYS=

# ========== Webhook ==========
WEBHOOK_GITHUB_SECRET=
WEBHOOK_GITLAB_SECRET=

# ========== 可选 ==========
# DEBUG=true
# DATA_DIR=data
# REPORTS_DIR=data/reports
